<% @interview ||= OpenStruct.new(
  id: 0,
  overall_score: 8,
  feedback_summary: "Strong performance overall. You demonstrated good technical knowledge and communicated your past experience effectively. Focus on quantifying your impact in future answers.",
  category: "General",
  role: nil,
  answers: []
) %>
<% @role ||= @interview.role %>

<% content_for :title, "Interview Results — #{@role&.title || "Practice"}" %>

<div style="background:var(--bg);min-height:calc(100vh - 68px);padding:3rem 1rem">
  <div style="max-width:780px;margin:0 auto">

    <%# Back link %>
    <%= link_to "← Back to interview", interview_path(@interview),
        style: "font-size:.83rem;color:var(--ink-3);text-decoration:none;display:inline-flex;align-items:center;gap:.4rem;margin-bottom:1.5rem" %>

    <%# ── Section 1: Results hero ──────────────────────────────────────────── %>
    <div style="background:#0f0a1e;border-radius:20px;padding:2.5rem;margin-bottom:1.5rem;position:relative;overflow:hidden">
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 80% 50%,rgba(108,62,244,.2),transparent)"></div>
      <div style="position:relative;z-index:1;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1.5rem">
        <div style="flex:1">
          <div style="font-size:.75rem;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.5rem">
            Interview Results
          </div>
          <h1 style="font-size:1.8rem;font-weight:800;color:#fff;letter-spacing:-.03em;margin-bottom:1.25rem">
            <%= @role ? @role.title : "Practice Interview" %>
          </h1>
          <% summary = @interview.feedback_summary.presence %>
          <% if summary %>
            <% sentences = summary.split(/(?<=\.)\s+/) %>
            <% strength = sentences.first %>
            <% improvement = sentences.drop(1).join(' ').presence %>
            <div style="font-size:.88rem;color:#fff;font-weight:600;line-height:1.6;margin-bottom:.75rem;">
              <%= strength %>
            </div>
            <% if improvement %>
              <div style="height:1px;background:rgba(255,255,255,.1);margin-bottom:.75rem;"></div>
              <div style="display:flex;align-items:flex-start;gap:.5rem;">
                <span style="font-size:.8rem;color:#fbbf24;flex-shrink:0;margin-top:1px;">💡</span>
                <span style="font-size:.82rem;color:rgba(255,255,255,.55);line-height:1.6;"><%= improvement %></span>
              </div>
            <% end %>
          <% else %>
            <div style="font-size:.88rem;color:rgba(255,255,255,.55);line-height:1.6;">
              Great effort! Keep practicing to sharpen your answers.
            </div>
          <% end %>
        </div>
        <div style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:16px;padding:1.5rem;text-align:center;min-width:140px;flex-shrink:0">
          <span style="font-size:3rem;font-weight:800;color:#fff;line-height:1;display:block">
            <%= @interview.overall_score || "—" %><span style="font-size:1.4rem;color:rgba(255,255,255,.4)">/10</span>
          </span>
          <span style="font-size:.72rem;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:.08em;margin-top:6px;display:block">
            Overall Score
          </span>
          <% if @interview.overall_score %>
            <% label, color = case @interview.overall_score
               when 8..10 then ["Excellent", "#4ade80"]
               when 6..7  then ["Good", "#a78bfa"]
               when 4..5  then ["Fair", "#fbbf24"]
               else            ["Keep going", "#f87171"]
               end %>
            <span style="font-size:.72rem;font-weight:700;color:<%= color %>;margin-top:4px;display:block"><%= label %></span>
          <% end %>
        </div>
      </div>
    </div>

    <% answers = @interview.answers.to_a %>

    <%# ── Section 2: What you did well ────────────────────────────────────── %>
    <% strong_answers = answers.select { |a| a.score && a.score >= 7 } %>
    <% if strong_answers.any? %>
      <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:16px;padding:2rem;margin-bottom:1.5rem;">
        <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:1.25rem;">
          <span style="font-size:1.25rem;">💪</span>
          <div style="font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#166534;">
            What you did well
          </div>
        </div>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:.6rem;margin:0;padding:0;">
          <% strong_answers.each do |answer| %>
            <li style="display:flex;align-items:flex-start;gap:.6rem;font-size:.875rem;color:#166534;line-height:1.6;">
              <span style="color:#22c55e;font-weight:700;flex-shrink:0;">✓</span>
              <%= answer.feedback.to_s.split('.').first %>.
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# ── Section 3: Focus for next session ───────────────────────────────── %>
    <% weak_answers = answers.select { |a| a.score && a.score < 7 }.first(3) %>
    <% if weak_answers.any? %>
      <div style="background:#fefce8;border:1px solid #fde047;border-radius:16px;padding:2rem;margin-bottom:1.5rem;">
        <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:1.25rem;">
          <span style="font-size:1.25rem;">🎯</span>
          <div style="font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#854d0e;">
            Focus for next session
          </div>
        </div>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:.6rem;margin:0;padding:0;">
          <% weak_answers.each do |answer| %>
            <% tip = answer.feedback.to_s.split('.').drop(1).map(&:strip).reject(&:empty?).first %>
            <% next if tip.blank? %>
            <li style="display:flex;align-items:flex-start;gap:.6rem;font-size:.875rem;color:#854d0e;line-height:1.6;">
              <span style="flex-shrink:0;">→</span>
              <%= tip %>.
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# ── Section 4: Question breakdown ───────────────────────────────────── %>
    <% if answers.any? %>
      <div class="wu-card mb-4">
        <div style="font-size:.78rem;font-weight:700;color:var(--ink-3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:1.25rem">
          Question Breakdown
        </div>

        <% answers.each_with_index do |ans, i| %>
          <div style="padding:1rem 0;border-bottom:1px solid var(--border)<%= i == answers.size - 1 ? ';border-bottom:none' : '' %>">
            <div class="d-flex justify-content-between align-items-center mb-2 gap-2">
              <div style="font-size:.83rem;font-weight:600;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:80%;">
                Q<%= i + 1 %><% if ans.question.present? %>: <%= ans.question %><% end %>
              </div>
              <% if ans.score %>
                <% badge_bg = ans.score >= 8 ? '#d1fae5' : ans.score >= 6 ? '#F3F0FF' : ans.score >= 4 ? '#fef9c3' : '#fee2e2' %>
                <% badge_color = ans.score >= 8 ? '#065f46' : ans.score >= 6 ? '#5A2ED9' : ans.score >= 4 ? '#854d0e' : '#991b1b' %>
                <span style="background:<%= badge_bg %>;color:<%= badge_color %>;font-weight:700;font-size:.8rem;padding:4px 12px;border-radius:100px;white-space:nowrap;flex-shrink:0;">
                  <%= ans.score %>/10
                </span>
              <% end %>
            </div>

            <% if ans.answer.present? %>
              <div style="font-size:.83rem;color:var(--ink-2);background:#F9F9FB;border-radius:8px;padding:.75rem;margin-bottom:.6rem;line-height:1.6">
                <%= ans.answer %>
              </div>
            <% end %>

            <% if ans.feedback.present? %>
              <p style="font-size:.82rem;color:#52525B;line-height:1.65;margin-top:.5rem;margin-bottom:0;">
                <%= ans.feedback.to_s.split('.').first %>.
              </p>
              <% if ans.feedback.to_s.split('.').length > 1 %>
                <details style="margin-top:.3rem;">
                  <summary style="font-size:.78rem;color:#6C3EF4;font-weight:600;cursor:pointer;list-style:none;">
                    Read full feedback ↓
                  </summary>
                  <p style="font-size:.82rem;color:#52525B;line-height:1.65;margin-top:.5rem;margin-bottom:0;">
                    <%= ans.feedback.to_s.split('.').drop(1).join('.').strip %>
                  </p>
                </details>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Actions ──────────────────────────────────────────────────────────── %>
    <div class="d-flex gap-3 flex-wrap">
      <% if @role %>
        <%= link_to "Practice again →", new_role_interview_path(@role), class: "btn-wu btn-wu-primary" %>
        <%= link_to "Back to role", role_path(@role), class: "btn-wu btn-wu-outline" %>
      <% end %>
      <%= link_to "My profile", analyses_path, class: "btn-wu btn-wu-outline" %>
    </div>

  </div>
</div>
