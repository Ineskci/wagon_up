<% @interviews ||= [] %>
<% @role ||= nil %>


<div class="wu-interview-layout">

  <%# ── Sidebar ───────────────────────────────────────────────────────────── %>
  <div class="wu-sidebar" id="wuSidebar">
    <div class="wu-sidebar-inner">

      <button class="btn-wu btn-wu-primary btn-wu-full mb-3" type="button" disabled>
        + Nova Sessão
      </button>

      <div style="font-size:.72rem;font-weight:700;color:var(--ink-3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.6rem">
        Sessões Anteriores
      </div>

      <% if @interviews.any? %>
        <% @interviews.each do |interview| %>
          <%= link_to interview_path(interview), class: "wu-session-item text-decoration-none", style: "display:flex" do %>
            <div style="flex:1">
              <div style="font-size:.83rem;font-weight:600;color:var(--ink)"><%= interview.category.presence || "Entrevista" %></div>
              <div style="font-size:.72rem;color:var(--ink-3)"><%= interview.created_at.strftime("%d %b %Y") rescue "—" %></div>
            </div>
            <span class="wu-score-pill"><%= interview.overall_score ? "#{interview.overall_score}/10" : "—" %></span>
          <% end %>
        <% end %>
      <% else %>
        <p style="font-size:.8rem;color:var(--ink-3);padding:.5rem .75rem;line-height:1.6">
          O histórico de sessões aparecerá aqui. Pronta para começar? 💪
        </p>
      <% end %>

      <div style="height:1px;background:var(--border);margin:1rem 0"></div>

      <div style="font-size:.72rem;font-weight:700;color:var(--ink-3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.75rem">
        Progresso da Sessão
      </div>

      <div class="d-flex justify-content-between" style="font-size:.82rem;margin-bottom:.3rem">
        <span>Perguntas</span>
        <span style="font-weight:600">0/<%= InterviewsController::TOTAL_QUESTIONS %></span>
      </div>
      <div class="wu-progress mb-3">
        <div class="wu-progress-fill" style="width:0%"></div>
      </div>

      <div class="d-flex justify-content-between" style="font-size:.82rem;margin-bottom:.3rem">
        <span>Média</span>
        <span style="font-weight:600">—</span>
      </div>
      <div class="wu-progress mb-3">
        <div class="wu-progress-fill" style="width:0%"></div>
      </div>

      <div style="height:1px;background:var(--border);margin:1rem 0"></div>

      <div style="font-size:.72rem;font-weight:700;color:var(--ink-3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.75rem">
        Dicas da Chloe
      </div>
      <p style="font-size:.8rem;color:var(--ink-2);line-height:1.6;margin-bottom:.75rem">
        💡 Use o método STAR: Situação, Tarefa, Acção, Resultado.
      </p>
      <p style="font-size:.8rem;color:var(--ink-2);line-height:1.6;margin-bottom:.75rem">
        💡 A tua carreira anterior é uma vantagem — liga sempre ao passado.
      </p>
      <p style="font-size:.8rem;color:var(--ink-2);line-height:1.6;margin-bottom:.75rem">
        💡 Pausa antes de responder. Mostra confiança, não hesitação.
      </p>

    </div>
  </div>

  <button class="wu-sidebar-toggle" id="wuSidebarToggle" aria-label="Toggle sidebar">‹</button>

  <%# ── Chat area ─────────────────────────────────────────────────────────── %>
  <div class="wu-chat-area"
       data-controller="chat"
       data-chat-role-id-value="<%= @role&.id %>">

    <div class="wu-chat-header">
      <div class="d-flex align-items-center gap-3">
        <div class="wu-chloe-avatar">🤖</div>
        <div>
          <div style="font-weight:700">Chloe 2.0</div>
          <div style="font-size:.75rem;color:var(--ink-3)">
            Coach de Entrevistas IA<% if @role %> · <strong style="color:var(--brand)"><%= @role.title %></strong><% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="wu-chat-messages" data-chat-target="messages">
      <div class="wu-msg bot">
        <div class="wu-chloe-avatar" style="width:32px;height:32px;font-size:.85rem;flex-shrink:0">🤖</div>
        <div class="wu-msg-bubble">
          Olá, <%= current_user.name.split.first %>!
          <% if @role %>
            Hoje vamos praticar para o cargo de <strong><%= @role.title %></strong>.
          <% end %>
          Vou fazer <%= InterviewsController::TOTAL_QUESTIONS %> perguntas. Diz olá para começarmos! 👋
        </div>
      </div>
    </div>

    <div class="wu-chat-input-row">
      <textarea class="wu-chat-input" rows="1"
                placeholder="Escreve algo para começar…"
                data-chat-target="input"
                data-action="keydown.enter->chat#start:prevent"></textarea>
      <button type="button" class="wu-btn-send" data-action="click->chat#start">➤</button>
    </div>

  </div>
</div>
