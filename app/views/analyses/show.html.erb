<% content_for :title, "#{current_user.name} — Profile" %>

<% if @analysis.status == "processing" %>
  <%# Polling activo enquanto o job ainda corre %>
  <div data-controller="polling"></div>
<% end %>

<turbo-frame id="analysis-content">

<% if @analysis.status == "processing" %>

  <div class="profile-hero">
    <div class="container position-relative" style="z-index:1">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <div style="font-size:.78rem;color:rgba(255,255,255,.45);letter-spacing:.08em;text-transform:uppercase;margin-bottom:.5rem">Your Analysis</div>
          <h1 style="font-size:2.2rem;font-weight:800;color:#fff;letter-spacing:-.03em;margin-bottom:.4rem"><%= current_user.name %></h1>
          <p style="color:rgba(255,255,255,.6);font-size:.95rem">We are analysing your CV...</p>
        </div>
        <div class="match-badge" style="opacity:.4">
          <span class="match-pct">--</span>
          <span class="match-lbl">Analysing</span>
        </div>
      </div>
    </div>
  </div>

  <div class="container py-7 text-center">
    <div style="max-width:480px;margin:0 auto;padding:4rem 0">
      <div style="font-size:3rem;margin-bottom:1.5rem">✦</div>
      <h2 style="font-size:1.4rem;font-weight:700;margin-bottom:.75rem">We are working on it</h2>
      <p style="color:var(--ink-3);font-size:.9rem;line-height:1.7;margin-bottom:2rem">
        We're analysing your CV. This takes about 1–2 minutes.<br>
      </p>
      <div style="display:flex;justify-content:center;gap:.5rem">
        <span style="width:8px;height:8px;border-radius:50%;background:var(--brand);animation:pulse 1.2s ease-in-out infinite"></span>
        <span style="width:8px;height:8px;border-radius:50%;background:var(--brand);animation:pulse 1.2s ease-in-out .4s infinite"></span>
        <span style="width:8px;height:8px;border-radius:50%;background:var(--brand);animation:pulse 1.2s ease-in-out .8s infinite"></span>
      </div>
    </div>
  </div>

  <style>
    @keyframes pulse {
      0%, 100% { opacity: .2; transform: scale(.8); }
      50%       { opacity: 1;  transform: scale(1.2); }
    }
  </style>

<% elsif @analysis.status == "failed" %>

  <div class="container py-7 text-center">
    <div style="max-width:480px;margin:4rem auto">
      <div style="font-size:3rem;margin-bottom:1rem">⚠️</div>
      <h2 style="font-size:1.3rem;font-weight:700;margin-bottom:.5rem">Something went wrong</h2>
      <p style="color:var(--ink-3);font-size:.9rem">An error occurred while processing your CV. Please try again.</p>
      <%= link_to "Submit another CV", new_analysis_path, class: "btn-primary mt-3 d-inline-block" %>
    </div>
  </div>

<% else %>

<%
  # ── Data helpers ──────────────────────────────────────────────────────────
  devicon_base = "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons"

  # Map skill name → short key used in data-skill and highlights arrays
  skill_key = ->(name) {
    n = name.to_s.downcase.strip
    if    n == "git/github" || n == "git / github"          then "git"
    elsif n == "html/css"   || n == "html / css"            then "html"
    elsif n.include?("ruby on rails") || n == "rails"       then "rails"
    elsif n.include?("ruby")                                then "ruby"
    elsif n.include?("typescript")                          then "ts"
    elsif n.include?("javascript") || n == "js"             then "js"
    elsif n.include?("next.js") || n.include?("nextjs")     then "nextjs"
    elsif n.include?("react")                               then "react"
    elsif n.include?("postgresql") || n.include?("sql")     then "sql"
    elsif n.include?("python")                              then "python"
    elsif n.include?("html")                                then "html"
    elsif n.include?("css")                                 then "css"
    elsif n.include?("github")                              then "github"
    elsif n.include?("git")                                 then "git"
    elsif n.include?("figma")                               then "figma"
    elsif n.include?("heroku")                              then "heroku"
    elsif n.include?("websocket")                           then "websocket"
    elsif n.include?("node")                                then "nodejs"
    elsif n.include?("docker")                              then "docker"
    elsif n.include?("kubernetes") || n == "k8s"            then "kubernetes"
    elsif n.include?("amazon") || n == "aws"                then "aws"
    elsif n.include?("redis")                               then "redis"
    elsif n.include?("graphql")                             then "graphql"
    elsif n.include?("tailwind")                            then "tailwind"
    elsif n.include?("bootstrap")                           then "bootstrap"
    elsif n.include?("sass") || n.include?("scss")          then "sass"
    elsif n.include?("vue")                                 then "vue"
    elsif n.include?("angular")                             then "angular"
    elsif n.include?("django")                              then "django"
    elsif n.include?("flask")                               then "flask"
    elsif n.include?("fastapi")                             then "fastapi"
    elsif n.include?("spring")                              then "spring"
    elsif n.include?("mongodb") || n.include?("mongo")      then "mongodb"
    elsif n.include?("mysql")                               then "mysql"
    elsif n.include?("firebase")                            then "firebase"
    elsif n.include?("supabase")                            then "supabase"
    elsif n.include?("prisma")                              then "prisma"
    elsif n.include?("stripe")                              then "stripe"
    elsif n.include?("openai")                              then "openai"
    elsif n.include?("rest api") || n == "rest"             then "rest"
    elsif n.include?("postman")                             then "postman"
    elsif n.include?("linux")                               then "linux"
    elsif n.include?("bash")                                then "bash"
    elsif n.include?("ci/cd") || n.include?("cicd")        then "cicd"
    elsif n.include?("github actions")                      then "ghactions"
    elsif n.include?("vercel")                              then "vercel"
    elsif n.include?("netlify")                             then "netlify"
    elsif n.include?("cloudflare")                          then "cloudflare"
    elsif n.include?("nginx")                               then "nginx"
    elsif n.include?("swift")                               then "swift"
    elsif n.include?("kotlin")                              then "kotlin"
    elsif n.include?("flutter")                             then "flutter"
    elsif n.include?("react native")                        then "react"
    elsif n.include?("solidity")                            then "solidity"
    elsif n.include?("web3")                                then "web3"
    elsif n.include?("webpack")                             then "webpack"
    elsif n.include?("vite")                                then "vite"
    elsif n.include?("operat")                              then "ops"
    elsif n.include?("leadership") || n.include?("manag")   then "leadership"
    elsif n.include?("problem")                             then "problem"
    elsif n.include?("critical")                            then "critical"
    elsif n.include?("adapt")                               then "adapt"
    elsif n.include?("empath")                              then "empathy"
    elsif n.include?("curiosit")                            then "curiosity"
    elsif n.include?("kpi")                                 then "kpis"
    elsif n.include?("communic")                            then "comm"
    elsif n.include?("teamwork") || n.include?("collab")    then "teamwork"
    elsif n.include?("ownership")                           then "ownership"
    elsif n.include?("resilien")                            then "resilience"
    elsif n.include?("time manag")                          then "time"
    elsif n.include?("creativ")                             then "creativity"
    elsif n.include?("roadmap")                             then "roadmap"
    elsif n.include?("priorit")                             then "priorit"
    elsif n.include?("stakeholder")                         then "stakeholder"
    elsif n.include?("wireframe")                           then "wireframe"
    elsif n.include?("user journey")                        then "user_journey"
    elsif n.include?("smart")                               then "smart"
    elsif n.include?("feature")                             then "feature"
    elsif n.include?("agile")                               then "agile"
    elsif n.include?("scrum")                               then "scrum"
    elsif n.include?("kanban")                              then "kanban"
    elsif n.include?("analyt") || n.include?("analís")      then "analyt"
    else  n.gsub(/[^a-z0-9]/, "_")
    end
  }

  # devicon slug per key — this IS the hard-skills whitelist.
  # Any skill whose key is not here will NOT appear in the hard skills grid.
  devicons = {
    "rails"      => "rails/rails-plain",
    "ruby"       => "ruby/ruby-original",
    "js"         => "javascript/javascript-original",
    "ts"         => "typescript/typescript-original",
    "sql"        => "postgresql/postgresql-original",
    "html"       => "html5/html5-original",
    "css"        => "css3/css3-original",
    "git"        => "git/git-original",
    "github"     => "github/github-original",
    "figma"      => "figma/figma-original",
    "heroku"     => "heroku/heroku-original",
    "nodejs"     => "nodejs/nodejs-plain",
    "react"      => "react/react-original",
    "nextjs"     => "nextjs/nextjs-original",
    "python"     => "python/python-original",
    "websocket"  => "nodejs/nodejs-plain",
    "docker"     => "docker/docker-original",
    "kubernetes" => "kubernetes/kubernetes-plain",
    "aws"        => "amazonwebservices/amazonwebservices-original",
    "redis"      => "redis/redis-original",
    "graphql"    => "graphql/graphql-plain",
    "tailwind"   => "tailwindcss/tailwindcss-plain",
    "bootstrap"  => "bootstrap/bootstrap-original",
    "sass"       => "sass/sass-original",
    "vue"        => "vuejs/vuejs-original",
    "angular"    => "angularjs/angularjs-original",
    "django"     => "django/django-plain",
    "flask"      => "flask/flask-original",
    "mongodb"    => "mongodb/mongodb-original",
    "mysql"      => "mysql/mysql-original",
    "firebase"   => "firebase/firebase-plain",
    "swift"      => "swift/swift-original",
    "kotlin"     => "kotlin/kotlin-original",
    "flutter"    => "flutter/flutter-original",
    "linux"      => "linux/linux-original",
    "bash"       => "bash/bash-original",
    "webpack"    => "webpack/webpack-original",
    "vite"       => "vitejs/vitejs-original",
    "nginx"      => "nginx/nginx-original",
    "vercel"     => "vercel/vercel-original",
    "netlify"    => "netlify/netlify-original",
  }

  # Soft skill emoji — covers both selected and domain/methodological skills from CV
  soft_meta = {
    "ops"           => { emoji: "⚙️"  },
    "leadership"    => { emoji: "🏆"  },
    "problem"       => { emoji: "🧩"  },
    "critical"      => { emoji: "🔍"  },
    "adapt"         => { emoji: "🌱"  },
    "empathy"       => { emoji: "🤝"  },
    "curiosity"     => { emoji: "💡"  },
    "kpis"          => { emoji: "📊"  },
    "comm"          => { emoji: "💬"  },
    "teamwork"      => { emoji: "🤝"  },
    "ownership"     => { emoji: "🎯"  },
    "resilience"    => { emoji: "💪"  },
    "time"          => { emoji: "⏱️"  },
    "creativity"    => { emoji: "🎨"  },
    "roadmap"       => { emoji: "🗺️"  },
    "priorit"       => { emoji: "🔢"  },
    "stakeholder"   => { emoji: "🤝"  },
    "wireframe"     => { emoji: "📐"  },
    "user_journey"  => { emoji: "🗺️"  },
    "smart"         => { emoji: "🎯"  },
    "feature"       => { emoji: "✨"  },
    "agile"         => { emoji: "🔄"  },
    "scrum"         => { emoji: "🔄"  },
    "kanban"        => { emoji: "📋"  },
    "analyt"        => { emoji: "📈"  },
  }

  # Skills selected in the form
  form_hard = @analysis.hard_skills_selected.to_s.split(/,\s*/).reject(&:blank?)
  form_hard = ["Ruby on Rails", "Ruby", "JavaScript", "PostgreSQL", "HTML5", "CSS3", "Git", "GitHub", "Figma", "Heroku"] if form_hard.blank?

  form_soft = @analysis.soft_skills_selected.to_s.split(/,\s*/).reject(&:blank?)
  form_soft = ["Operations", "Leadership", "Problem Solving", "Critical Thinking", "Adaptability", "Empathy", "Curiosity", "KPIs"] if form_soft.blank?

  # Skills extracted from CV by Claude (analise_lacunas.tenho, saved in analysis.skills)
  # Items look like: "Ruby on Rails — fullstack (Le Wagon, 2 projects)", "React + JavaScript", "SQL & PostgreSQL"
  tenho_raw = (JSON.parse(@analysis.skills.to_s) rescue [])
  cv_skills = tenho_raw.flat_map { |s|
    skill_part = s.to_s.split(/\s*[—–]\s*/).first.to_s.strip
    skill_part.split(/\s*[+&]\s*/).map(&:strip)
  }.reject(&:blank?)

  # Merge all candidate hard skills, then split by whether they have a devicon
  all_hard = (form_hard + cv_skills).uniq { |s| skill_key.call(s) }
  hard_skills  = all_hard.select { |s| devicons.key?(skill_key.call(s)) }
  leftover_cv  = all_hard.reject { |s| devicons.key?(skill_key.call(s)) }

  # Soft skills = form soft + leftover CV skills (domain/methodological), deduplicated
  soft_skills = (form_soft + leftover_cv).uniq { |s| skill_key.call(s) }

  # ── Real API data from raw_json ──────────────────────────────────────────
  raw         = @analysis.raw_json || {}
  cargos      = raw["cargos_sugeridos"] || []

  roles       = @roles.presence || @analysis.roles.order(:position).limit(3).to_a
  top_role    = roles.first

  # Hero score from real API data
  hero_score  = cargos.first&.dig("percentual_compatibilidade") || 87

  # Chloe message
  chloe_msg   = @analysis.summary.presence || raw.dig("estudante", "resumo_chloe").presence || "Your profile is ready."
%>

<%# ── HERO ── %>
<div class="profile-hero" style="background:#0d0920;padding:3rem 0 2.5rem;position:relative;overflow:hidden;">
  <div class="container hero-inner" style="position:relative;z-index:1;">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-4">
      <div>
        <div class="hero-eyebrow">Your AI Analysis</div>
        <h1 class="hero-name"><%= current_user.name %></h1>
        <p class="hero-tagline"><%= @analysis.cv_text.present? ? chloe_msg.split(".").first(2).join(".") + "." : "Your full-stack profile is ready." %></p>
      </div>
      <div class="hero-score">
        <div class="hero-score-val" id="scoreVal" data-target="<%= hero_score %>">0%</div>
        <div class="hero-score-label">Overall Market Fit</div>
        <div class="hero-score-sub">↗ Top 15% of profiles</div>
      </div>
    </div>
  </div>
</div>

<%# ── CHLOE BANNER ── %>
<div class="chloe-banner">
  <div class="chloe-av-img">
    <%= image_tag "chloe_avatar.png", alt: "Chloe" %>
  </div>
  <div>
    <div class="chloe-label">Chloe's take on your profile</div>
    <p class="chloe-text"><%= raw(chloe_msg) %></p>
  </div>
</div>

<%# ── PAGE BODY ── %>
<div class="page-body">
  <div class="container">

    <div style="text-align:center;font-size:.78rem;color:var(--ink-3);margin-bottom:1.5rem;padding:.6rem;background:#fff;border:1px dashed var(--border);border-radius:10px;" class="sr">
      💡 <strong>Tip:</strong> Hover a career suggestion to see exactly which of your skills match — and why.
    </div>

    <div class="row g-4">

      <%# ── LEFT COLUMN — Skills ── %>
      <div class="col-12 col-lg-5">

        <%# HARD SKILLS %>
        <div class="card-wu-lg sr mb-4">
          <div class="section-label">Hard Skills</div>
          <div class="skill-grid" id="hardGrid">
            <% hard_skills.each do |skill| %>
              <% key  = skill_key.call(skill) %>
              <% icon = devicons[key] %>
              <div class="skill-cell" data-skill="<%= key %>">
                <div class="logo-wrap">
                  <% if icon %>
                    <img src="<%= devicon_base %>/<%= icon %>.svg"
                         alt="<%= skill %>"
                         <% if key == "github" %>style="filter:invert(1);background:#24292e;border-radius:50%;"<% end %>
                         onerror="this.style.display='none'"/>
                  <% else %>
                    <i class="fa-solid fa-code" style="color:var(--brand);font-size:1.4rem"></i>
                  <% end %>
                </div>
                <span class="skill-name"><%= skill %></span>
              </div>
            <% end %>
          </div>
        </div>

        <%# SOFT SKILLS %>
        <div class="card-wu-lg sr d1 mb-4">
          <div class="section-label sl-green">Soft Skills</div>
          <div class="skill-grid" id="softGrid">
            <% soft_skills.each do |skill| %>
              <% key  = skill_key.call(skill) %>
              <% meta = soft_meta[key] || { emoji: "✨", label: skill } %>
              <div class="skill-cell skill-cell-soft" data-skill="<%= key %>">
                <div class="skill-icon-emoji"><%= meta[:emoji] %></div>
                <span class="skill-name"><%= skill %></span>
              </div>
            <% end %>
          </div>
        </div>

        <%# ATS KEYWORDS %>
        <div class="card-wu-lg sr d2">
          <div class="section-label">ATS Keywords</div>
          <div style="font-size:.8rem;color:var(--ink-3);margin-bottom:1rem;line-height:1.55;background:var(--bg);border-radius:8px;padding:.75rem 1rem;border-left:3px solid var(--brand-dim);">
            These words help your CV pass automated filters before a human reads it.
          </div>
          <div class="keyword-tags" id="kwGrid">
            <% hard_skills.first(5).each do |kw| %>
              <span class="kw-tag kw-tech" data-skill="<%= skill_key.call(kw) %>"><%= kw %></span>
            <% end %>
            <% soft_skills.first(6).each do |kw| %>
              <span class="kw-tag kw-soft" data-skill="<%= skill_key.call(kw) %>"><%= kw %></span>
            <% end %>
          </div>
        </div>

      </div>

      <%# ── RIGHT COLUMN — Career Suggestions ── %>
      <div class="col-12 col-lg-7">

        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;" class="sr">
          <div class="section-label" style="margin-bottom:0">Career Suggestions</div>
          <span style="font-size:.75rem;color:var(--ink-3);">Based on your full profile</span>
        </div>

        <div class="why-box sr d1">
          <span style="font-size:1.1rem;flex-shrink:0;">💡</span>
          <div class="why-text">
            Each role was chosen because it values the intersection of
            <strong>operational leadership and technical execution</strong> —
            exactly where your profile is strongest. Hover any card to see the skill-by-skill reasoning.
          </div>
        </div>

        <% pill_classes = %w[match-green match-blue match-yellow] %>
        <% delay_classes = ["sr d1", "sr d2", "sr d3"] %>

        <%
          # PT+EN keyword aliases per skill key — used to match Portuguese API responses
          skill_aliases = {
            "rails"      => %w[rails],
            "ruby"       => %w[ruby],
            "js"         => %w[javascript typescript],
            "sql"        => %w[postgresql sql dados data banco database],
            "html"       => %w[html],
            "css"        => %w[css],
            "git"        => %w[git],
            "github"     => %w[github],
            "figma"      => %w[figma design prototip],
            "heroku"     => %w[heroku deploy],
            "ops"        => %w[opera operac logist process processos produto product],
            "leadership" => %w[lideran gestao gestão manag coordena equipe team squad],
            "problem"    => %w[problem resoluc soluç solut],
            "critical"   => %w[critico critical anali],
            "adapt"      => %w[adapt],
            "empathy"    => %w[empatia empathy stakeholder],
            "curiosity"  => %w[curiosit aprendiz learning],
            "kpis"       => %w[kpi metrica metric dados data],
            "comm"       => %w[comunic communic],
            "teamwork"   => %w[colabo colabor collab],
          }
        %>

        <% roles.each_with_index do |role, i| %>
          <% cargo       = cargos[i] || {} %>
          <% match_score = cargo["percentual_compatibilidade"] || [87, 82, 79][i] %>
          <% description = cargo["descricao"].presence || role.justification.to_s.truncate(140) %>
          <% breakdown   = cargo["breakdown"] || [] %>
          <%
            # Priority 1: explicit highlights stored on the role (seed / manual data)
            mf_highlights = role.market_fit&.dig("highlights")

            if mf_highlights.present?
              highlights = mf_highlights.to_json
            else
              # Priority 2: text search across all role fields (PT + EN aliases)
              cargo_text = [
                cargo["titulo"], cargo["descricao"], cargo["justificativa"],
                cargo["mensagem_chloe"],
                breakdown.map { |b| "#{b["passado"]} #{b["futuro"]}" }
              ].flatten.compact.join(" ").downcase

              skill_relevant = ->(name) {
                key = skill_key.call(name)
                aliases = skill_aliases[key] || []
                # Check alias keywords against cargo_text
                aliases.any? { |kw| cargo_text.include?(kw) } ||
                # Fallback: any word ≥4 chars from skill name
                name.to_s.downcase.split(/[\s\/\-]+/).select { |w| w.length >= 4 }.any? { |w| cargo_text.include?(w) }
              }

              highlights = (hard_skills + soft_skills)
                .select { |s| skill_relevant.call(s) }
                .map    { |s| skill_key.call(s) }
                .compact.uniq.to_json
            end
          %>

          <div class="career-card <%= delay_classes[i] %>"
               data-highlights="<%= highlights %>"
               onmouseenter="highlightSkills(this)"
               onmouseleave="clearHighlights()"
               onclick="window.location='<%= role_path(role) %>'">

            <div class="career-card-header">
              <div class="career-card-top">
                <div class="career-card-title"><%= role.title %></div>
                <span class="match-pill <%= pill_classes[i] %>"><%= match_score %>% match</span>
              </div>
              <p class="career-card-desc"><%= description %></p>
            </div>

            <% if breakdown.any? %>
              <div class="match-reasons">
                <% breakdown.first(3).each_with_index do |item, j| %>
                  <div class="match-reason">
                    <div class="mr-icon <%= j == 2 ? "green" : "" %>">✦</div>
                    <div class="mr-text">
                      <strong><%= item["passado"] %> →</strong> <%= item["futuro"] %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>

            <div class="career-card-footer">
              <%= link_to "See full details →", role_path(role), class: "btn-details", data: { turbo_frame: "_top" } %>
              <div class="match-bar-wrap">
                <div class="match-bar-track">
                  <div class="match-bar-fill" style="width:<%= match_score %>%"></div>
                </div>
                <span class="match-bar-pct"><%= match_score %>%</span>
              </div>
            </div>

          </div>
        <% end %>

        <% if roles.empty? %>
          <div style="padding:2rem;text-align:center;color:var(--ink-3);font-size:.9rem">
            Career suggestions are being generated. Please refresh in a moment.
          </div>
        <% end %>

      </div>
    </div>

    <%# ── CTA BOTTOM ── %>
    <div class="interview-cta sr">
      <div style="position:relative;z-index:1;">
        <div class="cta-title">Ready to practise for your interviews?</div>
        <p class="cta-sub">Chloe will ask you questions tailored to <strong>your profile and your target role</strong> — and score each answer in real time.</p>
      </div>
      <% if top_role %>
        <%= link_to new_role_interview_path(top_role), class: "btn-interview", data: { turbo_frame: "_top" } do %>
          Start interview prep →
        <% end %>
      <% else %>
        <span class="btn-interview" style="opacity:.5;cursor:not-allowed">Start interview prep →</span>
      <% end %>
    </div>

  </div>
</div>

<script>
/* ── SCORE COUNTER ── */
(function() {
  const el = document.getElementById('scoreVal');
  if (!el) return;
  const target = parseInt(el.dataset.target, 10) || 87;
  let cur = 0;
  const tick = () => {
    cur = Math.min(cur + 2, target);
    el.textContent = cur + '%';
    if (cur < target) requestAnimationFrame(tick);
  };
  setTimeout(() => requestAnimationFrame(tick), 300);
})();

/* ── SCROLL REVEAL ── */
const srObs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('up'); srObs.unobserve(e.target); } });
}, { threshold: .08 });
document.querySelectorAll('.sr').forEach(el => srObs.observe(el));

/* ── SKILL HIGHLIGHTING ── */
function highlightSkills(card) {
  const highlights = JSON.parse(card.dataset.highlights || '[]');
  document.querySelectorAll('#hardGrid .skill-cell').forEach(cell => {
    const match = highlights.includes(cell.dataset.skill);
    cell.classList.toggle('highlighted', match);
    cell.classList.toggle('dimmed', !match);
  });
  document.querySelectorAll('#softGrid .skill-cell').forEach(cell => {
    const match = highlights.includes(cell.dataset.skill);
    cell.classList.toggle('highlighted', match);
    cell.classList.toggle('dimmed', !match);
  });
  document.querySelectorAll('#kwGrid .kw-tag').forEach(tag => {
    const match = tag.dataset.skill && highlights.includes(tag.dataset.skill);
    tag.classList.toggle('highlighted', match);
    tag.style.opacity = match ? '1' : '0.3';
  });
}

function clearHighlights() {
  document.querySelectorAll('.skill-cell').forEach(c => c.classList.remove('highlighted', 'dimmed'));
  document.querySelectorAll('.kw-tag').forEach(t => { t.classList.remove('highlighted'); t.style.opacity = ''; });
}
</script>

<% end %>

</turbo-frame>
