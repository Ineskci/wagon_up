<% content_for :title, "#{current_user.name} — Profile" %>

<% if @analysis.status == "processing" %>
  <%# Polling activo enquanto o job ainda corre %>
  <div data-controller="polling"></div>
<% end %>

<turbo-frame id="analysis-content">

<% if @analysis.status == "processing" %>

  <div class="container py-7 text-center">
    <div style="max-width:520px;margin:0 auto;padding:4rem 0">

      <div class="loading-icon-wrap">
        <%= image_tag "chloe_avatar.png", alt: "Chloe", class: "loading-chloe-avatar" %>
      </div>

      <h2 style="font-size:1.4rem;font-weight:700;margin-bottom:.5rem">Chloe is on it</h2>
      <p style="color:var(--ink-3);font-size:.85rem;margin-bottom:2rem">This takes about 1–2 minutes</p>

      <div class="loading-message-wrap">
        <p class="loading-msg" id="loadingMsg">Identifying your transferable skills...</p>
      </div>

      <div class="loading-steps">
        <div class="loading-step active" id="step0">
          <div class="ls-dot"></div>
          <span>Identifying your transferable skills</span>
        </div>
        <div class="loading-step" id="step1">
          <div class="ls-dot"></div>
          <span>Mapping your career fit</span>
        </div>
        <div class="loading-step" id="step2">
          <div class="ls-dot"></div>
          <span>Building your personalized profile</span>
        </div>
      </div>

    </div>
  </div>

  <style>
    @keyframes pulse {
      0%, 100% { opacity: .2; transform: scale(.8); }
      50%       { opacity: 1;  transform: scale(1.2); }
    }
    @keyframes fadeSlideUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .loading-icon-wrap {
      width: 80px; height: 80px;
      border-radius: 50%;
      overflow: hidden;
      margin: 0 auto 1.5rem;
      border: 3px solid var(--brand-dim);
      animation: pulse 2s ease-in-out infinite;
    }
    .loading-chloe-avatar {
      width: 100%; height: 100%;
      object-fit: cover;
      transform: scale(1.9);
    }
    .loading-message-wrap {
      min-height: 2rem;
      margin-bottom: 2rem;
    }
    .loading-msg {
      font-size: .95rem;
      font-weight: 600;
      color: var(--brand);
      animation: fadeSlideUp .5s ease;
    }
    .loading-steps {
      display: flex;
      flex-direction: column;
      gap: .75rem;
      text-align: left;
      max-width: 320px;
      margin: 0 auto;
    }
    .loading-step {
      display: flex;
      align-items: center;
      gap: .75rem;
      font-size: .85rem;
      color: var(--ink-3);
      transition: color .4s;
    }
    .loading-step.active { color: var(--ink); font-weight: 600; }
    .loading-step.done   { color: var(--ink-3); text-decoration: line-through; }
    .loading-step.done .ls-dot   { background: #16a34a; }
    .loading-step.active .ls-dot { background: var(--brand); animation: pulse 1s ease-in-out infinite; }
    .ls-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--border);
      flex-shrink: 0;
      transition: background .4s;
    }
  </style>

  <script>
    (function() {
      const analysisId = "<%= @analysis.id %>";
      const messages = [
        "Identifying your transferable skills...",
        "Mapping your career fit...",
        "Building your personalized profile..."
      ];

      // Reset state if this is a new analysis
      if (window._loadingAnalysisId !== analysisId) {
        window._loadingAnalysisId = analysisId;
        window._loadingStep = 0;
        window._loadingTimersSet = false;
      }

      // Re-apply the stored step to the current DOM (called after every Turbo refresh)
      function applyState() {
        const current = window._loadingStep || 0;
        for (let i = 0; i < messages.length; i++) {
          const el = document.getElementById('step' + i);
          if (!el) continue;
          el.classList.remove('active', 'done');
          if (i < current)        el.classList.add('done');
          else if (i === current) el.classList.add('active');
        }
        const msgEl = document.getElementById('loadingMsg');
        if (msgEl) msgEl.textContent = messages[current];
      }

      // Always re-apply on each Turbo render
      applyState();

      // Only start timers once per analysis
      if (window._loadingTimersSet) return;
      window._loadingTimersSet = true;

      function advance() {
        window._loadingStep = Math.min((window._loadingStep || 0) + 1, messages.length - 1);
        applyState();
      }

      setTimeout(() => advance(), 20000);
      setTimeout(() => advance(), 40000);
    })();
  </script>

<% elsif @analysis.status == "failed" %>

  <div class="container py-7 text-center">
    <div style="max-width:480px;margin:4rem auto">
      <div style="font-size:3rem;margin-bottom:1rem">⚠️</div>
      <h2 style="font-size:1.3rem;font-weight:700;margin-bottom:.5rem">Something went wrong</h2>
      <p style="color:var(--ink-3);font-size:.9rem">An error occurred while processing your CV. Please try again.</p>
      <%= link_to "Submit another CV", new_analysis_path, class: "btn-primary mt-3 d-inline-block" %>
    </div>
  </div>

<% else %>

<%
  # ── Data helpers ──────────────────────────────────────────────────────────
  devicon_base = "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons"

  # Slug normalisation — must match what Claude returns in highlights.
  # Rule: lowercase, spaces→hyphens, "/"→"-", " on "→"-"
  skill_key = ->(name) {
    name.to_s.downcase.strip
        .gsub("/", "-")
        .gsub(" ", "-")
        .gsub("'", "")
        .squeeze("-")
  }

  # devicon path per slug — this IS the hard-skills whitelist.
  # Any skill whose slug is not here goes to the soft/domain grid instead.
  devicons = {
    "ruby-on-rails" => "rails/rails-plain",
    "ruby"          => "ruby/ruby-original",
    "javascript"    => "javascript/javascript-original",
    "typescript"    => "typescript/typescript-original",
    "sql"           => "postgresql/postgresql-original",
    "postgresql"    => "postgresql/postgresql-original",
    "html5"         => "html5/html5-original",
    "html-css"      => "html5/html5-original",
    "css3"          => "css3/css3-original",
    "git"           => "git/git-original",
    "git-github"    => "git/git-original",
    "github"        => "github/github-original",
    "figma"         => "figma/figma-original",
    "heroku"        => "heroku/heroku-original",
    "node.js"       => "nodejs/nodejs-plain",
    "websocket"     => "nodejs/nodejs-plain",
    "react"         => "react/react-original",
    "next.js"       => "nextjs/nextjs-original",
    "python"        => "python/python-original",
    "docker"        => "docker/docker-original",
    "kubernetes"    => "kubernetes/kubernetes-plain",
    "aws"           => "amazonwebservices/amazonwebservices-original",
    "redis"         => "redis/redis-original",
    "graphql"       => "graphql/graphql-plain",
    "tailwind"      => "tailwindcss/tailwindcss-plain",
    "bootstrap"     => "bootstrap/bootstrap-original",
    "sass"          => "sass/sass-original",
    "vue.js"        => "vuejs/vuejs-original",
    "angular"       => "angularjs/angularjs-original",
    "django"        => "django/django-plain",
    "flask"         => "flask/flask-original",
    "mongodb"       => "mongodb/mongodb-original",
    "mysql"         => "mysql/mysql-original",
    "firebase"      => "firebase/firebase-plain",
    "swift"         => "swift/swift-original",
    "kotlin"        => "kotlin/kotlin-original",
    "flutter"       => "flutter/flutter-original",
    "linux"         => "linux/linux-original",
    "bash"          => "bash/bash-original",
    "webpack"       => "webpack/webpack-original",
    "vite"          => "vitejs/vitejs-original",
    "nginx"         => "nginx/nginx-original",
    "vercel"        => "vercel/vercel-original",
    "netlify"       => "netlify/netlify-original",
    "openai-api"    => "openai/openai-original",
    "claude-code"   => nil,
    "canva"         => "canva/canva-original",
  }

  # Emoji per slug for soft/domain skills
  soft_meta = {
    "operations"             => { emoji: "⚙️" },
    "leadership"             => { emoji: "🏆" },
    "problem-solving"        => { emoji: "🧩" },
    "critical-thinking"      => { emoji: "🔍" },
    "adaptability"           => { emoji: "🌱" },
    "empathy"                => { emoji: "🤝" },
    "curiosity"              => { emoji: "💡" },
    "kpis"                   => { emoji: "📊" },
    "communication"          => { emoji: "💬" },
    "teamwork"               => { emoji: "🤝" },
    "ownership"              => { emoji: "🎯" },
    "resilience"             => { emoji: "💪" },
    "time-management"        => { emoji: "⏱️" },
    "creativity"             => { emoji: "🎨" },
    "roadmapping"            => { emoji: "🗺️" },
    "prioritization"         => { emoji: "🔢" },
    "stakeholder-management" => { emoji: "🎯" },
    "collaboration"          => { emoji: "🤝" },
    "autonomy"               => { emoji: "🦅" },
    "wireframes"             => { emoji: "📐" },
    "user-journey-mapping"   => { emoji: "🗺️" },
    "smart-methodology"      => { emoji: "🎯" },
    "feature-prioritization" => { emoji: "✨" },
    "agile"                  => { emoji: "🔄" },
    "scrum"                  => { emoji: "🔄" },
    "kanban"                 => { emoji: "📋" },
  }

  # Hard skills — form selection only, filtered to skills that have a devicon
  form_hard = @analysis.hard_skills_selected.to_s.split(/,\s*/).map(&:strip).reject(&:blank?)
  form_hard = ["Ruby on Rails", "Ruby", "JavaScript", "PostgreSQL", "HTML/CSS", "Git", "GitHub", "Figma", "Heroku"] if form_hard.blank?

  hard_skills   = form_hard.select { |s| devicons.key?(skill_key.call(s)) }
  leftover_form = form_hard.reject { |s| devicons.key?(skill_key.call(s)) }

  # Soft skills — form selection only + any hard-selected skill that had no devicon
  form_soft   = @analysis.soft_skills_selected.to_s.split(/,\s*/).map(&:strip).reject(&:blank?)
  form_soft   = ["Problem Solving", "Communication", "Adaptability", "Teamwork"] if form_soft.blank?

  soft_skills = (form_soft + leftover_form).uniq { |s| skill_key.call(s) }

  # ── Real API data from raw_json ──────────────────────────────────────────
  raw         = @analysis.raw_json || {}
  cargos      = raw["cargos_sugeridos"] || []

  roles       = @roles.presence || @analysis.roles.order(:position).limit(3).to_a
  top_role    = roles.first

  # Hero score from real API data
  hero_score  = cargos.first&.dig("percentual_compatibilidade") || 87

  # Chloe message
  chloe_msg   = @analysis.summary.presence || raw.dig("estudante", "resumo_chloe").presence || "Your profile is ready."
%>

<%# ── HERO ── %>
<div class="profile-hero" style="background:#0d0920;padding:3rem 0 2.5rem;position:relative;overflow:hidden;">
  <div class="container hero-inner" style="position:relative;z-index:1;">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-4">
      <div style="flex:1">
        <div class="hero-eyebrow">Your AI Analysis</div>
        <h1 class="hero-name"><%= current_user.name %></h1>
        <p class="hero-tagline"><%= raw.dig("estudante", "headline").presence || "Full Stack Developer" %></p>
        <div style="margin-top:1.25rem;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:1rem 1.15rem;">
          <div style="font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:.3rem;">WagonUp's take on your profile</div>
          <p style="font-size:.85rem;color:rgba(255,255,255,.75);line-height:1.65;margin:0;"><%= raw(chloe_msg) %></p>
        </div>
      </div>
      <div class="hero-score">
        <div class="hero-score-val" id="scoreVal" data-target="<%= hero_score %>">0%</div>
        <div class="hero-score-label">Overall Market Fit</div>
        <div class="hero-score-sub">↗ Top 15% of profiles</div>
      </div>
    </div>
  </div>
</div>

<%# ── PAGE BODY ── %>
<div class="page-body">
  <div class="container">

    <div style="text-align:center;font-size:.78rem;color:var(--ink-3);margin-bottom:1.5rem;padding:.6rem;background:#fff;border:1px dashed var(--border);border-radius:10px;" class="sr">
      💡 <strong>Tip:</strong> Hover a career suggestion to see exactly which of your skills match — and why.
    </div>

    <div class="row g-4">

      <%# ── LEFT COLUMN — Skills ── %>
      <div class="col-12 col-lg-5">

        <%# HARD SKILLS %>
        <div class="card-wu-lg sr mb-4">
          <div class="section-label">Hard Skills</div>
          <div class="skill-grid" id="hardGrid">
            <% hard_skills.each do |skill| %>
              <% key  = skill_key.call(skill) %>
              <% icon = devicons[key] %>
              <% if key == "openai-api" %>
                <div class="skill-cell" data-skill="openai-api">
                  <div class="logo-wrap" style="background:#000;border-radius:8px;width:30px;height:30px;display:flex;align-items:center;justify-content:center;">
                    <span style="color:#fff;font-size:.65rem;font-weight:800;letter-spacing:-.02em;">GPT</span>
                  </div>
                  <span class="skill-name">OpenAI API</span>
                </div>
              <% elsif key == "claude-code" %>
                <div class="skill-cell" data-skill="claude-code">
                  <div class="logo-wrap" style="background:#CC785C;border-radius:8px;width:30px;height:30px;display:flex;align-items:center;justify-content:center;">
                    <span style="color:#fff;font-size:.6rem;font-weight:800;">CC</span>
                  </div>
                  <span class="skill-name">Claude Code</span>
                </div>
              <% elsif icon %>
                <div class="skill-cell" data-skill="<%= key %>">
                  <div class="logo-wrap">
                    <img src="<%= devicon_base %>/<%= icon %>.svg"
                         alt="<%= skill %>"
                         <% if key == "github" %>style="filter:invert(1);background:#24292e;border-radius:50%;"<% end %>
                         onerror="this.style.display='none'"/>
                  </div>
                  <span class="skill-name"><%= skill %></span>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>

        <%# SOFT SKILLS %>
        <div class="card-wu-lg sr d1 mb-4">
          <div class="section-label sl-green">Soft Skills</div>
          <div class="skill-grid" id="softGrid">
            <% soft_skills.each do |skill| %>
              <% key  = skill_key.call(skill) %>
              <% meta = soft_meta[key] || { emoji: "✨", label: skill } %>
              <div class="skill-cell skill-cell-soft" data-skill="<%= key %>">
                <div class="skill-icon-emoji"><%= meta[:emoji] %></div>
                <span class="skill-name"><%= skill %></span>
              </div>
            <% end %>
          </div>
        </div>

        <%# ATS KEYWORDS %>
        <div class="card-wu-lg sr d2">
          <div class="section-label">ATS Keywords</div>
          <div style="font-size:.8rem;color:var(--ink-3);margin-bottom:1rem;line-height:1.55;background:var(--bg);border-radius:8px;padding:.75rem 1rem;border-left:3px solid var(--brand-dim);">
            These words help your CV pass automated filters before a human reads it.
          </div>
          <div id="kwGrid">
            <% ats_tech = @analysis.raw_json.dig("estudante", "ats_tech") || []
               ats_soft = @analysis.raw_json.dig("estudante", "ats_soft") || []

               if ats_tech.empty? && ats_soft.empty?
                 ats_tech = hard_skills.first(5)
                 ats_soft = soft_skills.first(4)
               end %>

            <% if ats_tech.any? %>
              <div class="keyword-group" style="margin-bottom:1rem;">
                <div class="keyword-group-title">⚙️ Technical</div>
                <div class="keyword-tags">
                  <% ats_tech.each do |kw| %>
                    <span class="kw-tag kw-tech" data-skill="<%= skill_key.call(kw) %>"><%= kw %></span>
                  <% end %>
                </div>
              </div>
            <% end %>

            <% if ats_soft.any? %>
              <div class="keyword-group">
                <div class="keyword-group-title">🧠 Behavioural</div>
                <div class="keyword-tags">
                  <% ats_soft.each do |kw| %>
                    <span class="kw-tag kw-soft" data-skill="<%= skill_key.call(kw) %>"><%= kw %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

      </div>

      <%# ── RIGHT COLUMN — Career Suggestions ── %>
      <div class="col-12 col-lg-7">

        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;" class="sr">
          <div class="section-label" style="margin-bottom:0">Career Suggestions</div>
          <span style="font-size:.75rem;color:var(--ink-3);">Based on your full profile</span>
        </div>

        <div class="why-box sr d1">
          <span style="font-size:1.1rem;flex-shrink:0;">💡</span>
          <div class="why-text">
            Each role was chosen because it values the intersection of
            <strong>operational leadership and technical execution</strong> —
            exactly where your profile is strongest. Hover any card to see the skill-by-skill reasoning.
          </div>
        </div>

        <% pill_classes = %w[match-green match-blue match-yellow] %>
        <% delay_classes = ["sr d1", "sr d2", "sr d3"] %>

        <% roles.each_with_index do |role, i| %>
          <% cargo       = cargos[i] || {} %>
          <% match_score = cargo["percentual_compatibilidade"] || [87, 82, 79][i] %>
          <% description = cargo["descricao"].presence || role.justification.to_s.truncate(140) %>
          <% breakdown   = cargo["breakdown"] || [] %>
          <% highlights  = role.market_fit&.dig("highlights") || [] %>

          <div class="career-card <%= delay_classes[i] %>"
               data-highlights="<%= highlights.to_json %>"
               onmouseenter="highlightSkills(this)"
               onmouseleave="clearHighlights()"
               onclick="window.location='<%= role_path(role) %>'">

            <div class="career-card-header">
              <div class="career-card-top">
                <div class="career-card-title"><%= role.title %></div>
                <span class="match-pill <%= pill_classes[i] %>"><%= match_score %>% match</span>
              </div>
              <p class="career-card-desc"><%= description %></p>
            </div>

            <% if breakdown.any? %>
              <div class="match-reasons">
                <% breakdown.first(3).each_with_index do |item, j| %>
                  <div class="match-reason">
                    <div class="mr-icon <%= j == 2 ? "green" : "" %>">✦</div>
                    <div class="mr-text">
                      <strong><%= item["passado"] %> →</strong> <%= item["futuro"] %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>

            <div class="career-card-footer">
              <%= link_to "See full details →", role_path(role), class: "btn-details", data: { turbo_frame: "_top" } %>
              <div class="match-bar-wrap">
                <div class="match-bar-track">
                  <div class="match-bar-fill" style="width:<%= match_score %>%"></div>
                </div>
                <span class="match-bar-pct"><%= match_score %>%</span>
              </div>
            </div>

          </div>
        <% end %>

        <% if roles.empty? %>
          <div style="padding:2rem;text-align:center;color:var(--ink-3);font-size:.9rem">
            Career suggestions are being generated. Please refresh in a moment.
          </div>
        <% end %>

      </div>
    </div>

    <%# ── CTA BOTTOM ── %>
    <div class="interview-cta sr">
      <div style="position:relative;z-index:1;">
        <div class="cta-title">Ready to practise for your interviews?</div>
        <p class="cta-sub">Chloe will ask you questions tailored to <strong>your profile and your target role</strong> — and score each answer in real time.</p>
      </div>
      <% if top_role %>
        <%= link_to new_role_interview_path(top_role), class: "btn-interview", data: { turbo_frame: "_top" } do %>
          Start interview prep →
        <% end %>
      <% else %>
        <span class="btn-interview" style="opacity:.5;cursor:not-allowed">Start interview prep →</span>
      <% end %>
    </div>

  </div>
</div>

<script>
/* ── SCORE COUNTER ── */
function startScoreCounter() {
  const el = document.getElementById('scoreVal');
  if (!el || el.dataset.started) return;
  el.dataset.started = '1';
  const target = parseInt(el.dataset.target, 10) || 87;
  let cur = 0;
  const tick = () => {
    cur = Math.min(cur + 2, target);
    el.textContent = cur + '%';
    if (cur < target) requestAnimationFrame(tick);
  };
  setTimeout(() => requestAnimationFrame(tick), 300);
}
startScoreCounter();
document.addEventListener('turbo:load', startScoreCounter);
document.addEventListener('turbo:frame-render', startScoreCounter);

/* ── SCROLL REVEAL ── */
const srObs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('up'); srObs.unobserve(e.target); } });
}, { threshold: .08 });
document.querySelectorAll('.sr').forEach(el => srObs.observe(el));

/* ── SKILL HIGHLIGHTING ── */
function highlightSkills(card) {
  const highlights = JSON.parse(card.dataset.highlights || '[]');
  document.querySelectorAll('#hardGrid .skill-cell').forEach(cell => {
    const match = highlights.includes(cell.dataset.skill);
    cell.classList.toggle('highlighted', match);
    cell.classList.toggle('dimmed', !match);
  });
  document.querySelectorAll('#softGrid .skill-cell').forEach(cell => {
    const match = highlights.includes(cell.dataset.skill);
    cell.classList.toggle('highlighted', match);
    cell.classList.toggle('dimmed', !match);
  });
  document.querySelectorAll('#kwGrid .kw-tag').forEach(tag => {
    const match = tag.dataset.skill && highlights.includes(tag.dataset.skill);
    tag.classList.toggle('highlighted', match);
    tag.style.opacity = match ? '1' : '0.3';
  });
}

function clearHighlights() {
  document.querySelectorAll('.skill-cell').forEach(c => c.classList.remove('highlighted', 'dimmed'));
  document.querySelectorAll('.kw-tag').forEach(t => { t.classList.remove('highlighted'); t.style.opacity = ''; });
}
</script>

<% end %>

</turbo-frame>
