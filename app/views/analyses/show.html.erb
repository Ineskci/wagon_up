<% content_for :title, "#{current_user.name} — Profile" %>

<% if @analysis.status == "processing" %>
  <%# Polling activo enquanto o job ainda corre %>
  <div data-controller="polling"></div>
<% end %>

<turbo-frame id="analysis-content">

<% if @analysis.status == "processing" %>

  <div class="container py-7 text-center">
    <div style="max-width:520px;margin:0 auto;padding:4rem 0">

      <div class="loading-icon-wrap">
        <%= image_tag "chloe_avatar.png", alt: "Chloe", class: "loading-chloe-avatar" %>
      </div>

      <h2 style="font-size:1.4rem;font-weight:700;margin-bottom:.5rem">Chloe is on it</h2>
      <p style="color:var(--ink-3);font-size:.85rem;margin-bottom:2rem">This takes about 1–2 minutes</p>

      <div class="loading-message-wrap">
        <p class="loading-msg" id="loadingMsg">Identifying your transferable skills...</p>
      </div>

      <div class="loading-steps">
        <div class="loading-step active" id="step0">
          <div class="ls-dot"></div>
          <span>Identifying your transferable skills</span>
        </div>
        <div class="loading-step" id="step1">
          <div class="ls-dot"></div>
          <span>Mapping your career fit</span>
        </div>
        <div class="loading-step" id="step2">
          <div class="ls-dot"></div>
          <span>Building your personalized profile</span>
        </div>
      </div>

    </div>
  </div>

  <style>
    @keyframes pulse {
      0%, 100% { opacity: .2; transform: scale(.8); }
      50%       { opacity: 1;  transform: scale(1.2); }
    }
    @keyframes fadeSlideUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .loading-icon-wrap {
      width: 80px; height: 80px;
      border-radius: 50%;
      overflow: hidden;
      margin: 0 auto 1.5rem;
      border: 3px solid var(--brand-dim);
      animation: pulse 2s ease-in-out infinite;
    }
    .loading-chloe-avatar {
      width: 100%; height: 100%;
      object-fit: cover;
      transform: scale(1.9);
    }
    .loading-message-wrap {
      min-height: 2rem;
      margin-bottom: 2rem;
    }
    .loading-msg {
      font-size: .95rem;
      font-weight: 600;
      color: var(--brand);
      animation: fadeSlideUp .5s ease;
    }
    .loading-steps {
      display: flex;
      flex-direction: column;
      gap: .75rem;
      text-align: left;
      max-width: 320px;
      margin: 0 auto;
    }
    .loading-step {
      display: flex;
      align-items: center;
      gap: .75rem;
      font-size: .85rem;
      color: var(--ink-3);
      transition: color .4s;
    }
    .loading-step.active { color: var(--ink); font-weight: 600; }
    .loading-step.done   { color: var(--ink-3); text-decoration: line-through; }
    .loading-step.done .ls-dot   { background: #16a34a; }
    .loading-step.active .ls-dot { background: var(--brand); animation: pulse 1s ease-in-out infinite; }
    .ls-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--border);
      flex-shrink: 0;
      transition: background .4s;
    }
  </style>

  <script>
    (function() {
      const analysisId = "<%= @analysis.id %>";
      const messages = [
        "Identifying your transferable skills...",
        "Mapping your career fit...",
        "Building your personalized profile..."
      ];

      // Reset state if this is a new analysis
      if (window._loadingAnalysisId !== analysisId) {
        window._loadingAnalysisId = analysisId;
        window._loadingStep = 0;
        window._loadingTimersSet = false;
      }

      // Re-apply the stored step to the current DOM (called after every Turbo refresh)
      function applyState() {
        const current = window._loadingStep || 0;
        for (let i = 0; i < messages.length; i++) {
          const el = document.getElementById('step' + i);
          if (!el) continue;
          el.classList.remove('active', 'done');
          if (i < current)        el.classList.add('done');
          else if (i === current) el.classList.add('active');
        }
        const msgEl = document.getElementById('loadingMsg');
        if (msgEl) msgEl.textContent = messages[current];
      }

      // Always re-apply on each Turbo render
      applyState();

      // Only start timers once per analysis
      if (window._loadingTimersSet) return;
      window._loadingTimersSet = true;

      function advance() {
        window._loadingStep = Math.min((window._loadingStep || 0) + 1, messages.length - 1);
        applyState();
      }

      setTimeout(() => advance(), 20000);
      setTimeout(() => advance(), 40000);
    })();
  </script>

<% elsif @analysis.status == "failed" %>

  <div class="container py-7 text-center">
    <div style="max-width:480px;margin:4rem auto">
      <div style="font-size:3rem;margin-bottom:1rem">⚠️</div>
      <h2 style="font-size:1.3rem;font-weight:700;margin-bottom:.5rem">Something went wrong</h2>
      <p style="color:var(--ink-3);font-size:.9rem">An error occurred while processing your CV. Please try again.</p>
      <%= link_to "Submit another CV", new_analysis_path, class: "btn-primary mt-3 d-inline-block" %>
    </div>
  </div>

<% else %>

  <div class="profile-hero">
    <div class="container position-relative" style="z-index:1">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div style="max-width:55%">
          <div style="font-size:.78rem;color:rgba(255,255,255,.45);letter-spacing:.08em;text-transform:uppercase;margin-bottom:.5rem">Your Analysis</div>
          <h1 style="font-size:2.2rem;font-weight:800;color:#fff;letter-spacing:-.03em;margin-bottom:.4rem"><%= current_user.name %></h1>
          <p style="color:rgba(255,255,255,.6);font-size:.85rem;line-height:1.6"><%= @analysis.summary.present? ? @analysis.summary : "Full Stack Developer & Tech Problem Solver" %></p>
        </div>
        <div class="match-badge">
          <span class="match-pct">92%</span>
          <span class="match-lbl">Overall Market Fit</span>
          <span class="match-sub">↗ Top 15% of profiles</span>
        </div>
      </div>
    </div>
  </div>

  <div class="container py-7">

<div class="row g-4">
      <div class="col-12 col-lg-5 sr">
        <%
          hard_skill_icons = {
            "JavaScript"    => "devicon-javascript-plain colored",
            "SQL"           => "devicon-postgresql-plain colored",
            "Figma"         => "devicon-figma-plain colored",
            "Git/GitHub"    => "devicon-github-original colored",
            "Ruby on Rails" => "devicon-rails-plain colored",
            "HTML/CSS"      => "devicon-html5-plain colored",
            "Heroku"        => "devicon-heroku-original colored",
            "WebSocket"     => "devicon-nodejs-plain colored",
          }
          soft_skill_icons = {
            "Problem Solving"  => "🧩",
            "Communication"    => "💬",
            "Adaptability"     => "🌱",
            "Teamwork"         => "🤝",
            "Time Management"  => "⏱️",
            "Critical Thinking"=> "🔍",
            "Resilience"       => "💪",
            "Empathy"          => "💛",
            "Ownership"        => "🎯",
            "Curiosity"        => "💡",
          }
          hard_skills = @analysis.hard_skills_selected.to_s.split(/,\s*/).reject(&:blank?)
          hard_skills = ["JavaScript", "Ruby on Rails", "HTML/CSS", "SQL", "Git/GitHub", "Figma", "Heroku"] if hard_skills.blank?
          soft_skills = @analysis.soft_skills_selected.to_s.split(/,\s*/).reject(&:blank?)
          soft_skills = ["Problem Solving", "Communication", "Adaptability", "Teamwork", "Ownership"] if soft_skills.blank?
        %>

        <div class="skill-icon-card mb-3">
          <div class="skill-section-label" style="color:var(--brand);border-color:var(--brand-dim)">Hard Skills</div>
          <div class="skill-icon-grid">
            <% hard_skills.each do |skill| %>
              <div class="skill-icon-item">
                <div class="skill-icon-box">
                  <% if (cls = hard_skill_icons[skill]) %>
                    <i class="<%= cls %>"></i>
                  <% else %>
                    <i class="fa-solid fa-code" style="color:var(--brand)"></i>
                  <% end %>
                </div>
                <span class="skill-icon-name"><%= skill %></span>
              </div>
            <% end %>
          </div>
        </div>

        <div class="skill-icon-card">
          <div class="skill-section-label" style="color:#16a34a;border-color:#dcfce7">Soft Skills</div>
          <div class="skill-icon-grid">
            <% soft_skills.each do |skill| %>
              <div class="skill-icon-item">
                <div class="skill-icon-box">
                  <span style="font-size:1.6rem"><%= soft_skill_icons[skill] || "✨" %></span>
                </div>
                <span class="skill-icon-name"><%= skill %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-7 sr d1">
        <div style="font-size:1rem;font-weight:700;margin-bottom:1rem">Career Suggestions</div>
        <div class="d-flex flex-column gap-3">
          <% if @analysis.roles.any? %>
            <% @analysis.roles.order(:position).limit(3).each_with_index do |role, i| %>
              <% pills = ["", "style='background:#dbeafe;color:#1e40af'", "style='background:#fef9c3;color:#854d0e'"] %>
              <% pcts = ["87%", "82%", "79%"] %>
              <div class="career-card" onclick="window.location='<%= role_path(role) %>'">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <div>
                    <div style="font-size:1rem;font-weight:700;color:var(--ink)"><%= role.title %></div>
                    <div style="font-size:.82rem;color:var(--ink-3);margin-top:2px"><%= role.justification&.truncate(80) %></div>
                  </div>
                  <span class="match-pill" <%= pills[i].html_safe %>><%= pcts[i] %> match</span>
                </div>
                <%= link_to "See details →", role_path(role), class: "btn-outline-brand btn-sm mt-2", style: "font-size:.78rem", data: { turbo_frame: "_top" } %>
              </div>
            <% end %>
          <% else %>
            <% [["Junior Web Developer","87%",""],["Product Engineer","82%","style='background:#dbeafe;color:#1e40af'"],["Technical Project Manager","79%","style='background:#fef9c3;color:#854d0e'"]].each do |title, pct, pill| %>
              <div class="career-card" style="opacity:.7">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <div><div style="font-size:1rem;font-weight:700;color:var(--ink)"><%= title %></div></div>
                  <span class="match-pill" <%= pill.html_safe %>><%= pct %> match</span>
                </div>
                <button class="btn-outline-brand btn-sm mt-2" style="font-size:.78rem;opacity:.5" disabled>See details →</button>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

  </div>

  <div class="interview-cta-banner">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <div style="font-size:1.15rem;font-weight:700;color:#fff;margin-bottom:.35rem">Ready to practice for your interviews?</div>
          <div style="font-size:.88rem;color:rgba(255,255,255,.6);line-height:1.6">We will ask you questions tailored to <strong style="color:rgba(255,255,255,.85)">your profile and your target role</strong> and score each answer in real time.</div>
        </div>
        <% top_role = @analysis.roles.order(:position).first %>
        <% if top_role %>
          <%= link_to "Start interview →", new_role_interview_path(top_role), class: "btn-primary", style: "white-space:nowrap;padding:.85rem 2rem;font-size:1rem", data: { turbo_frame: "_top" } %>
        <% else %>
          <span class="btn-primary" style="white-space:nowrap;padding:.85rem 2rem;font-size:1rem;opacity:.5;cursor:not-allowed">Start interview →</span>
        <% end %>
      </div>
    </div>
  </div>

<% end %>

</turbo-frame>
