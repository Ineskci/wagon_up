<% content_for :title, "Set Up Your Profile" %>

<div class="setup-page">
  <div class="setup-card">

    <div class="progress-steps" id="setupProgress">
      <div class="ps-item active" id="step1-indicator">
        <div class="ps-circle">1</div>
        <span>CV Upload</span>
      </div>
      <div class="ps-line" id="ps-line-1"></div>
      <div class="ps-item" id="step2-indicator">
        <div class="ps-circle">2</div>
        <span>Your Background</span>
      </div>
    </div>

    <%= form_with model: @analysis, url: analyses_path, multipart: true do |f| %>
      <% if @analysis.errors.any? %>
        <div class="alert alert-danger"><%= @analysis.errors.full_messages.first %></div>
      <% end %>

      <!-- STEP 1: CV Upload -->
      <div id="setup-step1">
        <h2 style="font-size:1.6rem;font-weight:800;letter-spacing:-.02em;margin-bottom:.3rem">Set Up Your Profile</h2>

        <div class="mb-4">
          <div class="section-label">Upload Your CV</div>
          <div class="drop-zone" onclick="document.getElementById('cvInput').click()">
            <div class="drop-zone-icon">⬆️</div>
            <div style="font-size:.9rem;font-weight:600;color:var(--ink-2);margin-bottom:.25rem">Click to upload or drag your CV</div>
            <div style="font-size:.78rem;color:var(--ink-3)">PDF ou Word (.docx) · até 10MB</div>
            <%= f.file_field :file, id: "cvInput", accept: "application/pdf,.pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,.docx", class: "d-none", onchange: "handleCVUpload(this)" %>
          </div>
          <div id="cvFileName" style="font-size:.8rem;color:var(--brand);margin-top:.5rem;display:none"></div>
        </div>

        <div id="cvError" class="drop-zone-error" style="display:none">⚠️ Please upload your CV before continuing.</div>
        <button type="button" class="btn-primary-full" onclick="goSetupStep2()">Continue →</button>
      </div>

      <!-- STEP 2: Your Background -->
      <div id="setup-step2" style="display:none">
        <h2 style="font-size:1.6rem;font-weight:800;letter-spacing:-.02em;margin-bottom:.3rem">Set Up Your Profile</h2>
        <p class="text-brand fw-600 mb-4" style="font-size:.9rem">Would your like to add some skills?</p>

        <div class="mb-4">
          <div class="section-label">Technical Skills</div>
          <p style="font-size:.82rem;color:var(--ink-3);margin-bottom:.75rem">Choose skills to add</p>
          <div id="hardSkills">
            <span class="skill-tag" onclick="toggleTag(this)">JavaScript</span>
            <span class="skill-tag" onclick="toggleTag(this)">SQL</span>
            <span class="skill-tag" onclick="toggleTag(this)">Figma</span>
            <span class="skill-tag" onclick="toggleTag(this)">Git/GitHub</span>
            <span class="skill-tag" onclick="toggleTag(this)">Ruby on Rails</span>
            <span class="skill-tag" onclick="toggleTag(this)">HTML/CSS</span>
            <span class="skill-tag" onclick="toggleTag(this)">Heroku</span>
            <span class="skill-tag" onclick="toggleTag(this)">WebSocket</span>
          </div>
        </div>

        <div class="mb-4">
          <div class="section-label">Soft Skills</div>
          <p style="font-size:.82rem;color:var(--ink-3);margin-bottom:.75rem">Choose up to 5 skills</p>
          <div id="softSkills">
            <span class="skill-tag" onclick="toggleTag(this)">Problem Solving</span>
            <span class="skill-tag" onclick="toggleTag(this)">Communication</span>
            <span class="skill-tag" onclick="toggleTag(this)">Adaptability</span>
            <span class="skill-tag" onclick="toggleTag(this)">Teamwork</span>
            <span class="skill-tag" onclick="toggleTag(this)">Time Management</span>
            <span class="skill-tag" onclick="toggleTag(this)">Critical Thinking</span>
            <span class="skill-tag" onclick="toggleTag(this)">Resilience</span>
            <span class="skill-tag" onclick="toggleTag(this)">Empathy</span>
            <span class="skill-tag" onclick="toggleTag(this)">Ownership</span>
            <span class="skill-tag" onclick="toggleTag(this)">Curiosity</span>
          </div>
        </div>

<div class="mb-4">
          <div class="section-label">Where do you want to work?</div>
          <p style="font-size:.82rem;color:var(--ink-3);margin-bottom:.75rem">Select up to 3 countries</p>

          <div class="country-selector">
            <div class="country-chips" id="selectedCountries"></div>
            <input type="text" class="form-control-wu country-search-input" id="countrySearch"
                   placeholder="Search a country…" autocomplete="off">
            <div class="country-dropdown" id="countryDropdown" style="display:none"></div>
          </div>
          <div id="countryLimitMsg" style="display:none;font-size:.78rem;color:#b45309;margin-top:.4rem">⚠️ Maximum 3 markets selected.</div>
        </div>

        <%= f.hidden_field :hard_skills_selected, id: "hardSkillsInput" %>
        <%= f.hidden_field :soft_skills_selected, id: "softSkillsInput" %>
        <%= f.hidden_field :target_markets, id: "targetMarketsInput" %>

        <div class="d-flex gap-3">
          <button type="button" class="btn-outline-brand" onclick="goSetupStep1()">← Back</button>
          <%= f.submit "Analyse my profile →", class: "btn-primary-full flex-grow-1", onclick: "collectSkills()" %>
        </div>
      </div>

    <% end %>

  </div>
</div>
