<% content_for :title, "Set Up Your Profile" %>

<div class="setup-page">
  <div class="setup-card">

    <div class="progress-steps" id="setupProgress">
      <div class="ps-item active" id="step1-indicator">
        <div class="ps-circle">1</div>
        <span>CV Upload</span>
      </div>
      <div class="ps-line" id="ps-line-1"></div>
      <div class="ps-item" id="step2-indicator">
        <div class="ps-circle">2</div>
        <span>Your Background</span>
      </div>
    </div>

    <%= form_with model: @analysis, url: analyses_path, multipart: true do |f| %>
      <% if @analysis.errors.any? %>
        <div class="alert alert-danger"><%= @analysis.errors.full_messages.first %></div>
      <% end %>

      <!-- STEP 1: CV Upload -->
      <div id="setup-step1">
        <h2 style="font-size:1.6rem;font-weight:800;letter-spacing:-.02em;margin-bottom:.3rem">Set Up Your Profile</h2>

        <div class="mb-4">
          <div class="section-label">Upload Your CV</div>
          <div class="drop-zone" onclick="document.getElementById('cvInput').click()">
            <div class="drop-zone-icon">⬆️</div>
            <div style="font-size:.9rem;font-weight:600;color:var(--ink-2);margin-bottom:.25rem">Click to upload or drag your CV</div>
            <div style="font-size:.78rem;color:var(--ink-3)">PDF ou Word (.docx) · até 10MB</div>
            <%= f.file_field :file, id: "cvInput", accept: "application/pdf,.pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,.docx", class: "d-none", onchange: "handleCVUpload(this)" %>
          </div>
          <div id="cvFileName" style="font-size:.8rem;color:var(--brand);margin-top:.5rem;display:none"></div>
        </div>

        <div id="cvError" class="drop-zone-error" style="display:none">⚠️ Please upload your CV before continuing.</div>
        <button type="button" class="btn-primary-full" onclick="goSetupStep2()">Continue →</button>
      </div>

      <!-- STEP 2: Your Background -->
      <div id="setup-step2" style="display:none">
        <h2 style="font-size:1.6rem;font-weight:800;letter-spacing:-.02em;margin-bottom:.3rem">Set Up Your Profile</h2>
        <p class="text-brand fw-600 mb-4" style="font-size:.9rem">Would your like to add some skills?</p>

        <%# ── PROGRAM SELECTOR ── %>
        <div class="mb-4">
          <div class="section-label">🎓 Which Le Wagon program did you complete?</div>
          <p style="font-size:.82rem;color:#71717A;margin:.3rem 0 .75rem;">
            We'll pre-select your bootcamp skills automatically.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:.5rem;" id="programTags">
            <span class="program-tag" data-program="ai_software"    onclick="selectProgram(this)">🤖 AI Software Development</span>
            <span class="program-tag" data-program="data_analytics" onclick="selectProgram(this)">📊 Data Analytics</span>
            <span class="program-tag" data-program="data_science"   onclick="selectProgram(this)">🧪 Data Science</span>
            <span class="program-tag" data-program="data_engineering" onclick="selectProgram(this)">⚙️ Data Engineering</span>
            <span class="program-tag" data-program="growth_marketing" onclick="selectProgram(this)">🚀 Growth Marketing</span>
          </div>
          <p id="programConfirm" style="display:none;font-size:.8rem;color:#6C3EF4;font-weight:600;margin-top:.6rem;"></p>
        </div>

        <div class="mb-4">
          <div class="section-label">Technical Skills</div>
          <p style="font-size:.82rem;color:var(--ink-3);margin-bottom:.75rem">Choose skills to add</p>
          <div id="hardSkills">
            <span class="skill-tag" data-skill="JavaScript"    onclick="toggleTag(this)">JavaScript</span>
            <span class="skill-tag" data-skill="SQL"           onclick="toggleTag(this)">SQL</span>
            <span class="skill-tag" data-skill="Figma"         onclick="toggleTag(this)">Figma</span>
            <span class="skill-tag" data-skill="Git/GitHub"    onclick="toggleTag(this)">Git/GitHub</span>
            <span class="skill-tag" data-skill="Ruby on Rails" onclick="toggleTag(this)">Ruby on Rails</span>
            <span class="skill-tag" data-skill="HTML/CSS"      onclick="toggleTag(this)">HTML/CSS</span>
            <span class="skill-tag" data-skill="Heroku"        onclick="toggleTag(this)">Heroku</span>
            <span class="skill-tag" data-skill="WebSocket"     onclick="toggleTag(this)">WebSocket</span>
            <span class="skill-tag" data-skill="Ruby"          onclick="toggleTag(this)">Ruby</span>
            <span class="skill-tag" data-skill="OpenAI API"    onclick="toggleTag(this)">OpenAI API</span>
            <span class="skill-tag" data-skill="Claude Code"   onclick="toggleTag(this)">Claude Code</span>
            <span class="skill-tag" data-skill="Python"        onclick="toggleTag(this)">Python</span>
            <span class="skill-tag" data-skill="Google Analytics"    onclick="toggleTag(this)">Google Analytics</span>
            <span class="skill-tag" data-skill="Looker Studio"       onclick="toggleTag(this)">Looker Studio</span>
            <span class="skill-tag" data-skill="Google Ads"          onclick="toggleTag(this)">Google Ads</span>
            <span class="skill-tag" data-skill="HubSpot"             onclick="toggleTag(this)">HubSpot</span>
            <span class="skill-tag" data-skill="Semrush"             onclick="toggleTag(this)">Semrush</span>
            <span class="skill-tag" data-skill="Google Tag Manager"  onclick="toggleTag(this)">Google Tag Manager</span>
            <span class="skill-tag" data-skill="Make"                onclick="toggleTag(this)">Make</span>
            <span class="skill-tag" data-skill="Webflow"             onclick="toggleTag(this)">Webflow</span>
            <span class="skill-tag" data-skill="Notion"              onclick="toggleTag(this)">Notion</span>
            <span class="skill-tag" data-skill="Canva"               onclick="toggleTag(this)">Canva</span>
            <span class="skill-tag" data-skill="Lemlist"             onclick="toggleTag(this)">Lemlist</span>
            <span class="skill-tag" data-skill="Typeform"            onclick="toggleTag(this)">Typeform</span>
          </div>
        </div>

        <div class="mb-4">
          <div class="section-label">Soft Skills</div>
          <p style="font-size:.82rem;color:var(--ink-3);margin-bottom:.75rem">Choose up to 5 skills</p>
          <div id="softSkills">
            <span class="skill-tag" data-skill="Problem Solving"  onclick="toggleTag(this)">Problem Solving</span>
            <span class="skill-tag" data-skill="Communication"    onclick="toggleTag(this)">Communication</span>
            <span class="skill-tag" data-skill="Adaptability"     onclick="toggleTag(this)">Adaptability</span>
            <span class="skill-tag" data-skill="Teamwork"         onclick="toggleTag(this)">Teamwork</span>
            <span class="skill-tag" data-skill="Time Management"  onclick="toggleTag(this)">Time Management</span>
            <span class="skill-tag" data-skill="Critical Thinking" onclick="toggleTag(this)">Critical Thinking</span>
            <span class="skill-tag" data-skill="Resilience"       onclick="toggleTag(this)">Resilience</span>
            <span class="skill-tag" data-skill="Empathy"          onclick="toggleTag(this)">Empathy</span>
            <span class="skill-tag" data-skill="Ownership"        onclick="toggleTag(this)">Ownership</span>
            <span class="skill-tag" data-skill="Curiosity"        onclick="toggleTag(this)">Curiosity</span>
          </div>
        </div>

<div class="mb-4">
          <div class="section-label">Where do you want to work?</div>
          <p style="font-size:.82rem;color:var(--ink-3);margin-bottom:.75rem">Select up to 3 countries</p>

          <div class="country-selector">
            <div class="country-chips" id="selectedCountries"></div>
            <input type="text" class="form-control-wu country-search-input" id="countrySearch"
                   placeholder="Search a country…" autocomplete="off">
            <div class="country-dropdown" id="countryDropdown" style="display:none"></div>
          </div>
          <div id="countryLimitMsg" style="display:none;font-size:.78rem;color:#b45309;margin-top:.4rem">⚠️ Maximum 3 markets selected.</div>
        </div>

        <input type="hidden" id="wagon_program_field" name="wagon_program" />
        <%= f.hidden_field :hard_skills_selected, id: "hardSkillsInput" %>
        <%= f.hidden_field :soft_skills_selected, id: "softSkillsInput" %>
        <%= f.hidden_field :target_markets, id: "targetMarketsInput" %>

        <div class="d-flex gap-3">
          <button type="button" class="btn-outline-brand" onclick="goSetupStep1()">← Back</button>
          <%= f.submit "Analyse my profile →", class: "btn-primary-full flex-grow-1", onclick: "collectSkills()" %>
        </div>
      </div>

    <% end %>

  </div>
</div>

<script>
const WAGON_PROGRAMS = {
  ai_software: [
    "JavaScript", "SQL", "OpenAI API", "Figma",
    "Git/GitHub", "Ruby", "HTML/CSS", "Ruby on Rails",
    "Claude Code"
  ],
  data_analytics: [
    "Python", "SQL", "Google Analytics", "Looker Studio"
  ],
  data_science: [
    "Python", "SQL", "Git/GitHub"
  ],
  data_engineering: [
    "Python", "SQL", "Git/GitHub"
  ],
  growth_marketing: [
    "Notion", "Canva", "Google Ads", "HubSpot",
    "Semrush", "Google Analytics", "Looker Studio",
    "Google Tag Manager", "Make", "Webflow",
    "Lemlist", "Typeform"
  ]
}

function selectProgram(el) {
  // 1. Highlight selected program tag
  document.querySelectorAll('.program-tag').forEach(t => t.classList.remove('selected'))
  el.classList.add('selected')

  // 2. Save to hidden field
  document.getElementById('wagon_program_field').value = el.dataset.program

  // 3. Uncheck ALL skill tags first
  document.querySelectorAll('.skill-tag').forEach(t => t.classList.remove('active'))

  // 4. Check only skills for this program
  const programSkills = WAGON_PROGRAMS[el.dataset.program] || []
  document.querySelectorAll('.skill-tag').forEach(tag => {
    if (programSkills.includes(tag.dataset.skill)) {
      tag.classList.add('active')
    }
  })

  // 5. Show confirmation message
  const confirm = document.getElementById('programConfirm')
  confirm.textContent = '✓ ' + programSkills.length + ' skills pre-selected. Add anything extra you know on top.'
  confirm.style.display = 'block'
}
</script>
